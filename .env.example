APP_NAME=TinyTriggers
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

SUPABASE_URL=http://localhost:54321
SUPABASE_KEY=your-supabase-key
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=your_real_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
TAVILY_API_KEY=your_real_tavily_api_key
ENABLE_LIVE_EVIDENCE_SEARCH=true

AUTH_SECRET_KEY=change-me-to-a-long-random-secret
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENWEATHER_API_KEY=your_openweather_api_key
DEFAULT_WEATHER_LOCATION=Columbus,OH,US
WEATHER_UNITS=imperial

GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary
LOCAL_CALENDAR_DATA_FILE=data/calendar_events.json